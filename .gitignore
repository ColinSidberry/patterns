# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# scrape artifacts
/scripts/auth.json
/scripts/browser_profile/
/scripts/algo_monster_problems.json
/scripts/discovered_urls.json
/scripts/html/
/scripts/debug_*.txt
/scripts/debug_*.html

# typescript
*.tsbuildinfo
next-env.d.ts

# dev-only Claude → UI note inbox (see app/api/dev-notes/route.ts)
/.dev-notes-inbox.json

# Firebase admin service account key (never commit)
serviceAccount.json

# Local data backups (contain personal study data)
firestore-backup.json
flowpath-backup.json

# Internal tooling, data-pipeline artifacts & handoff docs — not part of the app
/scripts/
/test-results/
/.claude/
/IMPLEMENTATION_PLAN.md
/VIZ_SKILL_PLAN.md
*.excalidraw
